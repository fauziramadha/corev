{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/dist/server.js"
    }
  ],
  "functions": {
    "dist/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true"
  }
}
